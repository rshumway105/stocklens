# ═══════════════════════════════════════════════════════
# StockLens Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Only FRED_API_KEY is required. Everything else is optional.

# ── Required ──────────────────────────────────────────
# FRED API key for macroeconomic data (free)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Optional ──────────────────────────────────────────
# NewsAPI key for news headline sentiment (free tier: 100 req/day)
# Get yours at: https://newsapi.org/register
NEWSAPI_KEY=

# Reddit API for social sentiment (optional)
# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocklens/1.0

# ── Paths (defaults are fine for local dev) ───────────
DATABASE_PATH=data/stocklens.db
CACHE_DIR=data/cache

# ── App Settings ──────────────────────────────────────
LOG_LEVEL=INFO
